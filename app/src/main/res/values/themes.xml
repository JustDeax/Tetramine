<resources>
    <color name="ic_launcher_background">#000000</color>

    <style name="Theme.Dynamic" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar" />
    <style name="Theme.Static" parent="Theme.Material3.DayNight.NoActionBar" />
    <style name="Theme.Tetramine" parent="Theme.Static" />

    <style name="MainMenuCard" parent="Widget.MaterialComponents.CardView">
        <item name="android:layout_margin">8dp</item>
        <item name="contentPadding">20dp</item>
        <item name="strokeWidth">0.35dp</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerLowest</item>
        <item name="cardCornerRadius">28dp</item>
    </style>

    <style name="ButtonCard" parent="Widget.MaterialComponents.CardView">
        <item name="android:layout_margin">14dp</item>
        <item name="cardBackgroundColor">?attr/colorPrimaryContainer</item>
        <item name="cardCornerRadius">21dp</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">12dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="MonospaceTitle">
        <item name="android:fontFamily">@font/roboto_mono_semibold</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">34sp</item>
    </style>

    <style name="MainTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="StatisticsTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="StatisticsNumber" parent="StatisticsTitle">
        <item name="android:textColor">?attr/colorOnPrimaryContainer</item>
        <item name="android:textAlignment">textEnd</item>
        <item name="android:ellipsize">none</item>
    </style>

    <style name="StatisticsText">
        <item name="android:fontFamily">@font/roboto_mono_regular</item>
        <item name="android:layout_gravity">start|center_vertical</item>
    </style>

    <style name="MainButton" parent="Widget.Material3.Button">
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingLeft">18dp</item>
        <item name="android:paddingRight">18dp</item>
        <item name="android:textAlignment">center</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">18sp</item>
        <item name="cornerRadius">18dp</item>
        <item name="iconSize">20dp</item>
    </style>

    <style name="DialogGameButton" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:padding">12dp</item>
        <item name="maxLines">1</item>
    </style>

    <style name="DialogGameOutlineButton" parent="DialogGameButton">
        <item name="android:background">@color/invisible</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:tint">?attr/colorPrimary</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="AboutGameText" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">20sp</item>
    </style>

    <style name="ChooseModeTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textAlignment">center</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="ChooseModeDescription" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textAlignment">center</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:minLines">2</item>
        <item name="android:maxLines">2</item>
    </style>

    <style name="SettingsText" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">18sp</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <style name="SettingsButton" parent="MainButton">
        <item name="android:layout_marginStart">6dp</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:layout_marginBottom">2dp</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textAppearance">@style/SettingsText</item>
    </style>

    <style name="ChipGroup" parent="Widget.Material3.ChipGroup">
        <item name="chipSpacingHorizontal">0dp</item>
        <item name="selectionRequired">true</item>
        <item name="singleLine">true</item>
        <item name="singleSelection">true</item>
    </style>

    <style name="Chip" parent="Widget.MaterialComponents.Chip.Choice" />

    <style name="LeftChip" parent="Chip">
        <item name="shapeAppearance">@style/ShapeAppearanceOverlay.Material3.Corner.Left</item>
    </style>

    <style name="RightChip" parent="Chip">
        <item name="shapeAppearance">@style/ShapeAppearanceOverlay.Material3.Corner.Right</item>
    </style>

</resources>